{
  "name": "st-androids-missal",
  "productName": "St. Android's Missal",
  "private": true,
  "version": "1.16.34594",
  "type": "module",
  "description": "Traditional Latin Mass and Divine Office as a navigable subway map — graph + vector liturgical corpus, exegetical reader, perpetual calendar. Tauri 2 multiplatform.",
  "scripts": {
    "predev": "node scripts/sync-db.mjs",
    "dev": "vite",
    "prestamp": "node scripts/sync-db.mjs",
    "stamp": "node scripts/stamp-version.mjs",
    "collect-artifacts": "node scripts/collect-artifacts.mjs",
    "package:android-symbols": "bash scripts/package-android-symbols.sh",
    "prebuild": "node scripts/sync-db.mjs",
    "build": "tsc -b && vite build",
    "build:web": "npm run stamp && npm run build",
    "build:desktop": "npm run stamp && tauri build",
    "build:android": "npm run stamp && tauri android build --apk --aab",
    "build:windows:unstamped": "bash scripts/build-windows.sh",
    "build:release": "bash scripts/build-release.sh",
    "build:all": "npm run stamp && npm run build && tauri build && tauri android build --apk --aab",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "ingest": "node --experimental-strip-types scripts/ingest-corpus.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.4.0",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
